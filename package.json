{
  "name": "yard-manager",
  "version": "2.0.0",
  "description": "Yard Manager v2 — offline-first PWA with Svelte + Konva + IndexedDB sync",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "init-db": "node init-db.js",
    "migrate": "node migrations/run.js",
    "import-legacy": "node migrations/002_import_legacy.js",
    "build": "cd frontend && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:install": "cd frontend && npm install"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.12.0"
  }
}
