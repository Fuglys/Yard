# ── Dependencies ─────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Secrets / config ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Build output (Vite output naar ../public/assets) ─────────────
public/assets/
public/sw.js
public/sw.js.map
public/registerSW.js
public/workbox-*.js
public/workbox-*.js.map

# ── Frontend dev artefacten ──────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/node_modules/.vite/

# ── Graphify cache + tijdelijke staging-files ────────────────────
graphify-out/cache/
graphify-out/_svelte_stage/
graphify-out/diagnose-output.txt

# ── Editor / IDE ─────────────────────────────────────────────────
.vscode/*.log
.idea/
*.swp
*.swo

# ── OS junk ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database backups (laat db_dump.sql staan, dat is de master kopie) ─
*.dump
*.bak
db/local-*.sql
